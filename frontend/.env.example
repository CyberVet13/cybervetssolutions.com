# Environment Variables - Frontend
#
# What are environment variables?
# Settings that change per environment (dev, staging, production)
#
# Usage:
# 1. Copy this file: cp .env.example .env
# 2. In code: import.meta.env.VITE_API_URL
# 3. Vite auto-loads these when you run npm run dev
#
# IMPORTANT: Frontend env vars are visible in browser (not secret!)
# Only put public data here (API URLs, app names)
# Put secrets (API keys) on the backend!

# ============================================
# API Configuration
# ============================================

# Backend API base URL
# Where should the frontend send requests?
VITE_API_URL=http://localhost:3001

# API timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ============================================
# Application Settings
# ============================================

# App name (shown in browser title, etc.)
VITE_APP_NAME=CyberVets Solutions

# App version (from package.json)
VITE_APP_VERSION=0.1.0

# Current environment
VITE_ENVIRONMENT=development

# ============================================
# Analytics (Optional)
# ============================================

# Google Analytics key (optional)
VITE_GA_KEY=your_google_analytics_key

# Sentry project ID (error tracking)
# (Keep this public, it's just for grouping errors)
VITE_SENTRY_DSN=https://your_sentry_key@sentry.io/project_id

# ============================================
# Feature Flags
# ============================================

# Enable/disable features in UI
VITE_FEATURE_DEMO_MODE=false
VITE_FEATURE_BETA_FEATURES=false
