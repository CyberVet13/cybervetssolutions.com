# Environment Variables - Backend
#
# What are environment variables?
# Environment variables are secrets/settings that change per environment.
# 
# Examples:
# - Database password (different for dev, staging, production)
# - API keys (secret, never commit to GitHub!)
# - Feature flags (enable/disable features)
#
# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values
# 3. Run: npm run dev (or docker-compose up)
# 4. Node.js reads from .env automatically (via dotenv package)
#
# IMPORTANT: .env is NOT tracked by git (see .gitignore)
# This keeps secrets safe!
#
# FOR DOCKER:
# Use the values below when running via docker-compose
# The docker-compose.yml file will override these with proper container hostnames

# ============================================
# Database Configuration
# ============================================

# Format: postgresql://username:password@host:port/database
#
# LOCAL DEVELOPMENT (npm run dev):
#   DATABASE_URL=postgresql://cybervet:dev_password@localhost:5432/cybervet_dev
#
# DOCKER (docker-compose up):
#   DATABASE_URL=postgresql://cybervet:dev_password@postgres:5432/cybervet_dev
#   (Note: 'postgres' is the service name in docker-compose.yml)
#
DATABASE_URL=postgresql://cybervet:dev_password@localhost:5432/cybervet_dev

# PostgreSQL connection for migrations/seeds (alternative format)
DB_HOST=localhost
DB_PORT=5432
DB_USER=cybervet
DB_PASSWORD=dev_password
DB_NAME=cybervet_dev

# ============================================
# Redis Cache Configuration
# ============================================

# Format: redis://host:port/database
#
# LOCAL DEVELOPMENT (npm run dev):
#   REDIS_URL=redis://localhost:6379/0
#
# DOCKER (docker-compose up):
#   REDIS_URL=redis://redis:6379/0
#   (Note: 'redis' is the service name in docker-compose.yml)
#
REDIS_URL=redis://localhost:6379/0

# ============================================
# Application Settings
# ============================================

# What environment is this? (development, staging, production)
NODE_ENV=development

# What port should the server run on?
PORT=3001

# What's the base URL of this backend?
# (used for generating links, CORS, etc.)
API_URL=http://localhost:3001

# What's the URL of the frontend?
# (used for CORS - allowing frontend to call this backend)
FRONTEND_URL=http://localhost:3000

# ============================================
# Authentication (JWT)
# ============================================

# Secret key for signing JWT tokens
# Change this to a random string! (not "test_secret" in production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=test_secret_key_change_in_production

# How long should JWT tokens last? (in hours)
JWT_EXPIRATION=24

# ============================================
# Logging
# ============================================

# What level of logs to show? (error, warn, info, debug)
# - error: only errors
# - warn: errors + warnings
# - info: errors + warnings + info messages (recommended)
# - debug: everything (very verbose)
LOG_LEVEL=info

# ============================================
# External Services
# ============================================

# SendGrid (email service)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# AWS (S3 for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cybervet-dev

# MLS (Real Estate Data Source)
# Different MLS providers have different APIs
# Examples: NYMLS, SMLS, TMLS, Zillow API
MLS_API_KEY=your_mls_api_key_here
MLS_PROVIDER=your_mls_provider

# ============================================
# Feature Flags
# ============================================

# Enable/disable features without code changes
FEATURE_EMAIL_AUTOMATION=true
FEATURE_LEAD_SCORING=true
FEATURE_MARKET_ANALYSIS=true

# ============================================
# Development (Dev Tools)
# ============================================

# Allow running DB commands?
ALLOW_DB_RESET=true

# Enable detailed error messages?
DEBUG_MODE=false
