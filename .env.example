# Environment Configuration Template
# Copy to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/cybervetssolutions_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# SERVER
# ============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# OAuth (if using OAuth providers)
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback

# ============================================================================
# MLS INTEGRATION
# ============================================================================
# Regional MLS API keys (get from your MLS provider)
NYMLS_API_KEY=your-nymls-api-key
SMLS_API_KEY=your-smls-api-key
TMLS_API_KEY=your-tmls-api-key

# MLS Sync settings
MLS_SYNC_INTERVAL=3600000  # 1 hour in milliseconds
MLS_SYNC_BATCH_SIZE=100
MLS_API_TIMEOUT=30000      # 30 seconds

# ============================================================================
# EMAIL SERVICE
# ============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@cybervetssolutions.com
EMAIL_FROM_NAME=CyberVets Solutions

# Email template settings
EMAIL_TEMPLATE_DIR=./templates/emails
EMAIL_UNSUBSCRIBE_URL=http://localhost:3000/email/unsubscribe

# ============================================================================
# SMS SERVICE (Optional)
# ============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# AWS / CLOUD STORAGE
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=cybervetssolutions-dev
AWS_S3_UPLOAD_LIMIT_MB=50

# ============================================================================
# REDIS (Cache & Sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600  # 1 hour default cache TTL

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# Datadog (optional)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# SECURITY
# ============================================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS settings
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Session security
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_COOKIE_SECURE=false     # Set to true in production (HTTPS only)
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================================
# AI / ML SERVICES
# ============================================================================
# Lead Scorer service
LEAD_SCORER_URL=http://localhost:8001
LEAD_SCORER_MODEL_PATH=./models/lead-scorer.pkl

# Email NLP service
EMAIL_NLP_URL=http://localhost:8002

# ============================================================================
# PAYMENT (if applicable)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your-test-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-test-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_EMAIL_TEMPLATES=true
FEATURE_LEAD_SCORING=true
FEATURE_MARKET_INTELLIGENCE=true
FEATURE_TEAM_COORDINATION=false  # Coming soon

# ============================================================================
# DEVELOPMENT
# ============================================================================
DEBUG=*
DEVELOP_MODE=true

# AI Assistant settings (Claude Code development)
VIBE_CODING_ENABLED=true
CLAUDE_MODEL=claude-opus-4

# ============================================================================
# TESTING
# ============================================================================
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/cybervetssolutions_test
TEST_REDIS_URL=redis://localhost:6380
TEST_NODE_ENV=test

# ============================================================================
# EXAMPLES / DOCUMENTATION
# ============================================================================

# Use with: echo "NYMLS_API_KEY=$(echo $YOUR_MLS_KEY)" >> .env
# Or for production: use a secrets manager (AWS Secrets Manager, Vault, etc)

# Never commit .env to git:
# .env should be in .gitignore
# Use .env.example as a template for team members

